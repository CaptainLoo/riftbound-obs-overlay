{
  "name": "riftbound-obs-overlay",
  "version": "2.1.1",
  "description": "Riftbound stream overlay for OBS (Browser Source) with web control panel.",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/CaptainLoo/riftbound-obs-overlay.git"
  },
  "riftbound": {
    "updateRepo": "CaptainLoo/riftbound-obs-overlay"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "dev:electron": "electron .",
    "build:electron": "node scripts/build-electron.mjs",
    "build:win": "node scripts/build-win.mjs",
    "build:patch": "node scripts/build-patch.mjs",
    "build:installer": "node scripts/build-installer.mjs",
    "publish": "node scripts/publish-release.mjs",
    "setup:github": "node scripts/setup-github.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@elgato-stream-deck/node": "^7.6.3",
    "@electron/rebuild": "^4.1.0",
    "archiver": "^6.0.2",
    "express": "^4.19.2",
    "lowdb": "^7.0.1",
    "sharp": "^0.35.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "A1B2C3D4-E5F6-7890-ABCD-EF1234567890",
    "productName": "Riftbound OBS",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "extraFiles": [
      {
        "from": "dist/electron-bats",
        "to": "."
      }
    ],
    "extraResources": [
      {
        "from": "dist/electron-staging/riftbound",
        "to": "riftbound"
      },
      {
        "from": "electron/updater",
        "to": "updater"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "riftbound-setup-${version}.${ext}"
    }
  }
}
