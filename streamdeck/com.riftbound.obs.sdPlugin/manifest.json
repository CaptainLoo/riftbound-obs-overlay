{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "Riftbound OBS",
  "Version": "1.0.0.0",
  "Author": "Riftbound Community",
  "Category": "Riftbound OBS",
  "Description": "Control the Riftbound OBS overlay — show deck cards, matchup, scores. Syncs automatically with the local app.",
  "Icon": "imgs/plugin-icon",
  "CategoryIcon": "imgs/plugin-icon",
  "URL": "https://github.com/",
  "CodePath": "bin/plugin.js",
  "UUID": "com.riftbound.obs",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    { "Platform": "mac", "MinimumVersion": "12" },
    { "Platform": "windows", "MinimumVersion": "10" }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "Actions": [
    {
      "Name": "Show Card",
      "UUID": "com.riftbound.obs.showcard",
      "Icon": "imgs/action-show",
      "Tooltip": "Show a card from the player's imported deck on the overlay.",
      "PropertyInspectorPath": "ui/show-card.html",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/action-show", "TitleAlignment": "bottom", "FontSize": 10 }]
    },
    {
      "Name": "Hide All Cards",
      "UUID": "com.riftbound.obs.hideall",
      "Icon": "imgs/action-hide",
      "Tooltip": "Hide all on-demand cards and return to game view.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/action-hide", "TitleAlignment": "bottom", "FontSize": 10 }]
    },
    {
      "Name": "Hide Player Card",
      "UUID": "com.riftbound.obs.hideplayer",
      "Icon": "imgs/action-hide",
      "Tooltip": "Hide one player's on-demand card.",
      "PropertyInspectorPath": "ui/player.html",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/action-hide", "TitleAlignment": "bottom", "FontSize": 10 }]
    },
    {
      "Name": "Show Matchup",
      "UUID": "com.riftbound.obs.matchup",
      "Icon": "imgs/action-matchup",
      "Tooltip": "Full-screen matchup / deck reveal.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/action-matchup", "TitleAlignment": "bottom", "FontSize": 10 }]
    },
    {
      "Name": "Win Game",
      "UUID": "com.riftbound.obs.wingame",
      "Icon": "imgs/action-win",
      "Tooltip": "Register a game win for a player.",
      "PropertyInspectorPath": "ui/player.html",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/action-win", "TitleAlignment": "bottom", "FontSize": 10 }]
    },
    {
      "Name": "Select Game",
      "UUID": "com.riftbound.obs.game",
      "Icon": "imgs/action-game",
      "Tooltip": "Switch to game 1, 2 or 3.",
      "PropertyInspectorPath": "ui/game.html",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/action-game", "TitleAlignment": "bottom", "FontSize": 10 }]
    },
    {
      "Name": "Set Battlefield",
      "UUID": "com.riftbound.obs.battlefield",
      "Icon": "imgs/action-game",
      "Tooltip": "Set this player's battlefield for the current game.",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/action-game", "TitleAlignment": "bottom", "FontSize": 10 }]
    }
  ]
}
